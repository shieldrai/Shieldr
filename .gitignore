# Shieldr — .gitignore

# ---------------------------------------------------------------------------
# Secrets & Local Configuration
# ---------------------------------------------------------------------------
config/settings.yaml          # Contains API keys — NEVER commit
.env
.env.*
*.key
*.pem
*.p12
*.pfx
secrets/

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
MANIFEST

# Virtual environments
.venv/
venv/
env/
ENV/
.python-version

# ---------------------------------------------------------------------------
# Testing & Coverage
# ---------------------------------------------------------------------------
.pytest_cache/
.coverage
coverage.xml
htmlcov/
*.lcov
.tox/
nosetests.xml
test-results/

# ---------------------------------------------------------------------------
# Type Checking
# ---------------------------------------------------------------------------
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/
.pyre/

# ---------------------------------------------------------------------------
# IDEs & Editors
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace

# ---------------------------------------------------------------------------
# Logs & Runtime Artifacts
# ---------------------------------------------------------------------------
*.log
logs/
*.tmp
*.bak
*.orig
*.rej

# ---------------------------------------------------------------------------
# Build & Packaging
# ---------------------------------------------------------------------------
*.whl
*.tar.gz
*.zip
node_modules/
